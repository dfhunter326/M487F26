  <paragraphs xml:id="description">
    <title>Course Description</title>
    <p>
      This course is an introduction to Group Theory.
    </p>
  </paragraphs>

  <paragraphs xml:id="instructional-format">
    <title>Instructional Format</title>
    <p>This is a face-to-face course, which means we will meet in person.</p>
